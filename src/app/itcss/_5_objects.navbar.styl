.navbar
	&-fragment
		electron-titlebar()
		no-stacking-context()
		grid-area: navbar
		overflow: hidden

		&-inactive
			background-color: var(--inactive)

	&-title
		padding 0 140px
		width: 100%
		height: 100%

		display: flex
		flex-direction: row
		flex-wrap: wrap
		justify-content: center
		align-items: center
